# NanoClaw Configuration

# ============================================================================
# SLACK BOT CONFIGURATION
# ============================================================================

# PRODUCTION Slack Tokens (for Intel Mac / always-on deployment)
# Get these from https://api.slack.com/apps - see SLACK_SETUP.md for instructions
# You need BOTH tokens for Socket Mode to work:
# SLACK_BOT_TOKEN=xoxb-your-bot-user-oauth-token
# SLACK_APP_TOKEN=xapp-your-app-level-token

# DEVELOPMENT Slack Tokens (for M1 Mac / local testing)
# Create a separate Slack app for testing to keep dev and prod separate
# DEV_SLACK_BOT_TOKEN=xoxb-your-dev-bot-token
# DEV_SLACK_APP_TOKEN=xapp-your-dev-app-token

# Note: The application will use DEV_SLACK_BOT_TOKEN/DEV_SLACK_APP_TOKEN if set,
# otherwise falls back to SLACK_BOT_TOKEN/SLACK_APP_TOKEN


# ============================================================================
# ASSISTANT CONFIGURATION
# ============================================================================

# Name of your assistant (used in trigger pattern @{name})
ASSISTANT_NAME=StellarBot

# Set to true if using a dedicated bot (not a shared account)
# For Telegram, this should always be true since bots are dedicated
ASSISTANT_HAS_OWN_NUMBER=true


# ============================================================================
# ANTHROPIC API CONFIGURATION
# ============================================================================

# Required: Your Anthropic API key
# Get this from https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Optional: OAuth token for Claude Code features
# CLAUDE_CODE_OAUTH_TOKEN=...


# ============================================================================
# CONTAINER CONFIGURATION
# ============================================================================

# Container image name
CONTAINER_IMAGE=nanoclaw-agent:latest

# Container timeout (milliseconds) - default 30 minutes
CONTAINER_TIMEOUT=1800000

# Idle timeout (milliseconds) - how long to keep container alive after last result
IDLE_TIMEOUT=1800000

# Maximum concurrent containers
MAX_CONCURRENT_CONTAINERS=5

# Maximum container output size (bytes)
CONTAINER_MAX_OUTPUT_SIZE=10485760


# ============================================================================
# SCHEDULING CONFIGURATION
# ============================================================================

# Timezone for scheduled tasks (cron expressions)
# Auto-detected if not set
# TZ=Africa/Johannesburg


# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info
